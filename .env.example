CURSOR_API_KEY=
CURSOR_API_BASE_URL=https://api.cursor.com/v0

# Trigger service defaults
CURSOR_TARGET_REPOSITORY=https://github.com/your-org/your-repo
DEFAULT_SOURCE_REF=main
# Default tested model for this example. Replace if your account supports a different set.
DEFAULT_CURSOR_MODEL=gpt-5.4-high-fast
DEFAULT_AUTO_CREATE_PR=true
DEFAULT_OPEN_AS_CURSOR_GITHUB_APP=false
DEFAULT_SKIP_REVIEWER_REQUEST=false
TRIGGER_HOST=your-trigger-service
# Optional local or non-Render override
TRIGGER_BASE_URL=http://localhost:3000
CURSOR_WEBHOOK_SECRET=

# Slack
SLACK_SIGNING_SECRET=

# Linear
LINEAR_WEBHOOK_SECRET=
LINEAR_API_KEY=
LINEAR_COMMAND_PREFIX=@cursor

# Worker
CURSOR_TARGET_REF=main
CURSOR_GIT_USERNAME=x-access-token
CURSOR_GIT_TOKEN=
CURSOR_WORKER_SINGLE_USE=false
CURSOR_WORKER_IDLE_RELEASE_TIMEOUT=600
CURSOR_WORKER_MANAGEMENT_ADDR=
CURSOR_WORKER_EXTRA_ARGS=
